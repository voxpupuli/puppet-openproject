<%- | Hash[String, Any] $environment_contents | -%>
<% include stdlib -%>
<% $environment_contents.keys.sort.each |$key| { -%>
<% unless $environment_contents[$key] =~ Undef { -%>
<%= $key %>=<%= $environment_contents[$key] %>
<% } -%>
<% } -%>